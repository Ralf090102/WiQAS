# Frontend Environment Configuration
# PRE-CONFIGURED FOR GCP VM: wiqas-generation-evaluation-20260120-061404
#
# To change the VM IP, update VM_IP below — everything else updates automatically.

# VM EXTERNAL IP  ← only change this line when the IP changes
VM_IP=34.126.109.35

# Backend API URL
# For local development: http://localhost:8000
# For GCP deployment: http://<VM_IP>:8000
VITE_BACKEND_URL=http://${VM_IP}:8000

# Backend WebSocket URL
# For local development: ws://localhost:8000  
# For GCP deployment: ws://<VM_IP>:8000
VITE_BACKEND_WS=ws://${VM_IP}:8000

# ========================================
# GCP DEPLOYMENT INSTRUCTIONS
# ========================================

# 1. Copy this file to .env:
#    cp .env.example .env
#
# 2. Update VM_IP with your GCP VM's external IP:
#    VM_IP=<your-ip>
#
# 3. Build for production:
#    npm run build
#
# 4. Serve the built app:
#    npm run preview -- --host 0.0.0.0 --port 3000
#
# 5. Or use a production server like nginx or serve
